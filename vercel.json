{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/audit.py": {
      "runtime": "vercel-python@3.0.7"
    }
  },
  "rewrites": [
    {
      "source": "/audit",
      "destination": "/audit/index.html"
    },
    {
      "source": "/learn/regular-vs-direct-mutual-fund",
      "destination": "/learn/regular-vs-direct-mutual-fund/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/audit/",
      "destination": "/audit",
      "permanent": true
    },
    {
      "source": "/learn/regular-vs-direct-mutual-fund/",
      "destination": "/learn/regular-vs-direct-mutual-fund",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}